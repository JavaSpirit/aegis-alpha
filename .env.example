# Aegis Alpha local configuration template.
# Copy this file to .env and fill values locally. Never commit real secrets.

AEGIS_ALPHA_ENV=local
AEGIS_ALPHA_LOG_LEVEL=INFO

# Future market-data provider credentials. Leave blank in the MVP.
JVQUANT_API_KEY=
STOCKAPI_TOKEN=
MYQUANT_TOKEN=
MINIQMT_ACCOUNT_ID=

# Real trading is intentionally disabled in the MVP.
AEGIS_ALPHA_REAL_TRADING_ENABLED=false

