# Aegis Alpha local configuration template.
# Copy this file to .env.local or .env and fill values locally.
# Never commit real secrets.

AEGIS_ALPHA_ENV=local
AEGIS_ALPHA_LOG_LEVEL=INFO
AEGIS_ALPHA_MARKET_DATA_PROVIDER=mock

# jvQuant read-only market data.
# Keep the token in .env.local only; never paste it into chat or commit it.
JVQUANT_TOKEN=
JVQUANT_MARKET=ab
JVQUANT_SUBSCRIBE_SYMBOLS=600519,000001,002230
JVQUANT_ENABLE_LV1=true
JVQUANT_ENABLE_LV2=true
JVQUANT_ENABLE_LV10=true
JVQUANT_ENABLE_SQL=true
JVQUANT_WEBSOCKET_SERVER=
JVQUANT_SQL_SERVER=
AEGIS_ALPHA_ENABLE_MINUTE_REPLAY=true
AEGIS_ALPHA_SECOND_BOARD_MINUTE_REPLAY_LIMIT=12
AEGIS_ALPHA_BIG_ORDER_THRESHOLD_CNY=3000000
AEGIS_ALPHA_DATA_DIR=data
AEGIS_ALPHA_DB_PATH=data/aegis_alpha.db
AEGIS_ALPHA_RUNNER_STATUS_PATH=data/runner_status.json

# Optional future providers.
STOCKAPI_TOKEN=
MYQUANT_TOKEN=
MINIQMT_ACCOUNT_ID=

# Real trading is intentionally disabled in the MVP.
AEGIS_ALPHA_REAL_TRADING_ENABLED=false
